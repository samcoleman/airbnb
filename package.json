{
  "name": "airbnb-captive-portal",
  "version": "1.0.0",
  "description": "UniFi captive portal for Airbnb guest network",
  "private": true,
  "workspaces": [
    "site/backend",
    "site/frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev --workspace=site/backend",
    "dev:frontend": "npm run dev --workspace=site/frontend",
    "build": "npm run build --workspaces",
    "build:backend": "npm run build --workspace=site/backend",
    "build:frontend": "npm run build --workspace=site/frontend",
    "start": "npm run start --workspace=site/backend",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "clean": "rm -rf site/backend/dist site/frontend/dist site/backend/node_modules site/frontend/node_modules node_modules"
  },
  "keywords": [
    "captive-portal",
    "unifi",
    "solidjs",
    "fastify",
    "orpc",
    "airbnb"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
