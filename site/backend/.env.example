# UniFi Controller Configuration
UNIFI_URL=https://unifi-controller:8443
UNIFI_USER=admin
UNIFI_PASSWORD=your-password
UNIFI_SITE=default

# Guest Portal Configuration
GUEST_PASSWORD=your-shared-guest-password
PORTAL_NAME=Guest Portal

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DATABASE_PATH=./data/guest_portal.db

# Portal Content
WELCOME_MESSAGE=Welcome to our guest network!
TERMS_TEXT=Please accept our terms and conditions to use the guest network.

# Security
SESSION_TIMEOUT=3600
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=10
